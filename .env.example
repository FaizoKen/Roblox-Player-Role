DATABASE_URL=postgres://postgres:your_password@localhost:5432/roblox_player_role
SESSION_SECRET=your_session_secret
BASE_URL=http://localhost:8089/roblox-player-role
LISTEN_ADDR=0.0.0.0:8089
RUST_LOG=roblox_player_role=info,tower_http=info
AUTH_GATEWAY_URL=http://localhost:8080
INTERNAL_API_KEY=your_internal_api_key

# Roblox OAuth 2.0 — register the app at https://create.roblox.com/dashboard/credentials
# Redirect URI to register: {BASE_URL}/verify/callback
ROBLOX_CLIENT_ID=your_roblox_oauth_client_id
ROBLOX_CLIENT_SECRET=your_roblox_oauth_client_secret

# Public Roblox API requests per minute (per host).
ROBLOX_API_RATE_LIMIT=60
# Per-Open-Cloud-key DataStore requests per minute.
OPEN_CLOUD_RATE_LIMIT=300

# 32 bytes hex (64 chars). Used to AES-GCM-encrypt Roblox refresh tokens and
# Open Cloud API keys at rest. Generate one with:
#   openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=replace_with_64_hex_chars
